{
  "name": "sportsamigo-backend",
  "version": "1.0.0",
  "description": "SportsAmigo Backend API Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "perf:db": "node scripts/db-query-regression-check.js",
    "perf:redis": "node scripts/benchmark-redis-cache.js",
    "reindex:solr": "node scripts/reindex-solr.js",
    "seed:shop": "node seedShop.js",
    "seed:wallet": "node seedWallet.js",
    "seed:demo": "node scripts/seedDemoUsers.js"
  },
  "keywords": [
    "sports",
    "api",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^5.1.0",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.17.2",
    "razorpay": "^2.9.6",
    "resend": "^5.0.0",
    "rotating-file-stream": "^3.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "globalSetup": "./jest.globalSetup.js",
    "globalTeardown": "./jest.globalTeardown.js",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "./jest.setup.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "routes/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "!routes/health.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 40,
        "branches": 30,
        "functions": 40,
        "lines": 40
      }
    }
  }
}
