# Backend Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Use MONGO_URI on Render (MONGODB_URI is also supported by the app)
MONGO_URI=mongodb://localhost:27017/sportsamigo

# Session Secret
SESSION_SECRET=sportsamigo-app-secret-2023

# Cookie settings for cross-site deployments (Vercel frontend → Render backend)
# On Render: set NODE_ENV=production, COOKIE_SAME_SITE=none, COOKIE_SECURE=true
# Locally:   leave these unset (defaults: SameSite=Lax, Secure=false)
COOKIE_SAME_SITE=none
COOKIE_SECURE=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# JWT Secret (for token-based auth if needed)
JWT_SECRET=your-jwt-secret-key-change-in-production

# Razorpay Payment Gateway (use test keys for development)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Resend Email API (OTP emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=SportsAmigo <noreply@muthuraja.tech>
RESEND_TEST_EMAIL=your-resend-account-email@example.com
RESEND_ALLOW_SANDBOX_REDIRECT=false

# Advanced Search (Atlas Search with fuzzy matching)
ENABLE_ATLAS_SEARCH=false
ATLAS_SHOP_SEARCH_INDEX=shop_search
ATLAS_EVENT_SEARCH_INDEX=event_search

# Cloudinary (profile image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=sportsamigo/profile
MAX_PROFILE_IMAGE_BYTES=5242880

# Solr search optimization
ENABLE_SOLR_SEARCH=false
SOLR_BASE_URL=
SOLR_USERNAME=
SOLR_PASSWORD=
SOLR_EVENT_COLLECTION=events
SOLR_TEAM_COLLECTION=teams
SOLR_USER_COLLECTION=users
SOLR_TIMEOUT_MS=1500

# Local benchmark defaults
BENCH_BASE_URL=http://localhost:5000
BENCH_REQUESTS=50
BENCH_CONCURRENCY=10
