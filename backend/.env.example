# Backend Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Use MONGO_URI on Render (MONGODB_URI is also supported by the app)
MONGO_URI=mongodb://localhost:27017/sportsamigo

# Session Secret
SESSION_SECRET=sportsamigo-app-secret-2023

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# JWT Secret (for token-based auth if needed)
JWT_SECRET=your-jwt-secret-key-change-in-production

# Razorpay Payment Gateway (use test keys for development)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Resend Email API (OTP emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=SportsAmigo <noreply@muthuraja.tech>
RESEND_TEST_EMAIL=your-resend-account-email@example.com
RESEND_ALLOW_SANDBOX_REDIRECT=false
